platform :ios, '14.0'

target 'iosApp' do
  use_frameworks!

  # Google Mobile Ads (AdMob) — Werbung
  pod 'Google-Mobile-Ads-SDK'

  # Google User Messaging Platform (UMP) — GDPR Consent
  pod 'GoogleUserMessagingPlatform'

  # Firebase Cloud Messaging — Push Notifications
  pod 'FirebaseMessaging'

  # Google Sign-In — native OAuth flow for "Continue with Google" on iOS.
  # Replaces Supabase's Safari-redirect flow to avoid iPad multi-scene crashes.
  pod 'GoogleSignIn'
end

# Verhindert Signing-Konflikte bei CocoaPods-Pods
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end
end
